<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/orderRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#16213E"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="@drawable/icon_btn_bg"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/headerTableTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Table 1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Order"
                android:textSize="12sp"
                android:textColor="#E94560" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/statusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FREE"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/badge_free"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Customer Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOMER INFO"
                    android:textSize="11sp"
                    android:textColor="#E94560"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/customerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Customer Name"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp" />
            </LinearLayout>

            <!-- Order Items Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ORDER ITEMS"
                        android:textSize="11sp"
                        android:textColor="#E94560"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <Button
                        android:id="@+id/addItemButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="+ Add Item"
                        android:textSize="12sp"
                        android:backgroundTint="#E94560"
                        android:textColor="#FFFFFF"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />
                </LinearLayout>

                <!-- Column Headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        android:text="ITEM"
                        android:textSize="10sp"
                        android:textColor="#4A5568"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="QTY"
                        android:textSize="10sp"
                        android:textColor="#4A5568"
                        android:letterSpacing="0.1"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="10sp"
                        android:textColor="#4A5568" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/emptyItemsHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tap '+ Add Item' to start the order"
                    android:textColor="#4A5568"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp" />
            </LinearLayout>

            <!-- Special Instructions Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="16dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPECIAL INSTRUCTIONS"
                    android:textSize="11sp"
                    android:textColor="#E94560"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/specialInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Allergies, preferences, notes…"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#4A5568"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Send Button -->
    <Button
        android:id="@+id/sendButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📤  SEND ORDER TO KITCHEN"
        android:textStyle="bold"
        android:textSize="15sp"
        android:backgroundTint="#E94560"
        android:textColor="#FFFFFF"
        android:layout_margin="16dp" />

</LinearLayout>
